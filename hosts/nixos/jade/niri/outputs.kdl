// jade triple monitors
output "DP-3" {
    mode "1920x1080@60.000"
    scale 1.0
    position x=0 y=360
}
output "DP-4" {
    mode "2560x1440@59.951"
    scale 1.0
    position x=1920 y=0
    focus-at-startup
}
output "eDP-1" {
    mode "1920x1080@143.998"
    scale 1.0
    position x=4480 y=360
}
